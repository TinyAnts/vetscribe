# Copy this file to ".env" and paste your OpenAI API key below.
# The .env file is git-ignored and must NEVER be committed or uploaded.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-PASTE_YOUR_KEY_HERE

# ---- optional cost guards (safe defaults shown; uncomment to change) ----
# VS_DAILY_BUDGET_USD=20
# VS_MAX_AUDIO_SECONDS=300
# VS_MAX_GENS=5
# VS_MAX_TRANSCRIBE=8

